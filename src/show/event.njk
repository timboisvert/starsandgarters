---
layout: base.njk
pagination:
  data: collections.eventPages
  size: 1
  alias: eventPage
permalink: "/show/{{ eventPage.show.slug }}/{{ eventPage.slug }}/"
eleventyComputed:
  title: "{{ eventPage.title }}"
  meta:
    description: "{{ eventPage.description | default(eventPage.title) }}"
    image: "{{ (eventPage.poster and (site.url ~ '/posters/' ~ eventPage.poster)) or site.logo }}"
    url: "{{ site.url ~ '/show/' ~ eventPage.show.slug ~ '/' ~ eventPage.slug ~ '/' }}"
    ogType: "article"
---

<script type="application/ld+json">
{{ eventPage | eventPageSchema(site) | safe }}
</script>

<div>
    <div class="flex flex-col md:flex-row gap-12">
        {%- if eventPage.poster %}
        <div class="w-full md:w-1/2 shrink-0">
            <div class="aspect-[3/4] bg-neutral-900 overflow-hidden">
                <img src="/posters/{{ eventPage.poster }}" alt="{{ eventPage.title }}" class="w-full h-full object-cover">
            </div>
        </div>
        {%- endif %}

        <div class="flex-1">
            <p class="font-inter text-sm text-neutral-400 uppercase tracking-wide mb-2">
                <a href="/show/{{ eventPage.show.slug }}/" class="hover:text-white">{{ eventPage.show.title }}</a>
            </p>
            <h1 class="font-oswald font-bold text-5xl uppercase mb-6">{{ eventPage.shortTitle }}</h1>

            <div class="bg-neutral-900 border border-neutral-700 p-6 mb-8">
                <p class="font-inter text-xl text-white mb-1">{{ eventPage.date | longDate }}</p>
                <p class="font-inter text-lg text-neutral-300 mb-4">{{ eventPage.time }}</p>
                {%- if eventPage.ticketUrl %}
                <a href="{{ eventPage.ticketUrl }}" target="_blank" rel="noopener"
                   class="inline-block bg-white text-black font-inter text-base font-semibold px-6 py-3 hover:bg-neutral-200 transition-colors">
                    {{ eventPage.show.buttonText if eventPage.show.buttonText else "Buy Tickets" }}
                </a>
                {%- elif eventPage.freeAtDoor %}
                <p class="font-inter text-base text-white">Free at the door</p>
                {%- endif %}
            </div>

            {%- if eventPage.description %}
            <p class="font-inter text-lg text-neutral-400 mb-10 leading-normal whitespace-pre-line">{{ eventPage.description }}</p>
            {%- endif %}

            {%- if eventPage.dates | length > 1 %}
            <div class="mt-8 mb-10">
                <h2 class="font-oswald text-2xl uppercase mb-4">All Dates</h2>
                <div class="space-y-3">
                    {%- for d in eventPage.dates %}
                    <div class="flex items-center justify-between bg-neutral-800 p-4">
                        <div>
                            <p class="font-inter text-white">{{ d.date | longDate }}</p>
                            <p class="font-inter text-sm text-neutral-400">{{ d.time }}</p>
                        </div>
                        {%- if d.ticketUrl %}
                        <a href="{{ d.ticketUrl }}" target="_blank" rel="noopener"
                           class="font-inter text-sm bg-white text-black px-4 py-2 hover:bg-neutral-200 transition-colors">
                            Tickets
                        </a>
                        {%- elif d.freeAtDoor %}
                        <span class="font-inter text-sm text-neutral-300">Free at the door</span>
                        {%- endif %}
                    </div>
                    {%- endfor %}
                </div>
            </div>
            {%- endif %}

            <p class="font-inter text-neutral-500">
                <a href="/show/{{ eventPage.show.slug }}/" class="hover:text-white">&larr; See all {{ eventPage.show.title }} shows</a>
            </p>
        </div>
    </div>
</div>
