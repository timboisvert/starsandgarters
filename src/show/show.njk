---
layout: base.njk
pagination:
  data: shows
  size: 1
  alias: show
permalink: "/show/{{ show.slug }}/"
eleventyComputed:
  title: "{{ show.title }}"
  meta:
    description: "{{ show.description | default(show.tagline) }}"
    image: "{{ (show.poster and (site.url ~ '/posters/' ~ show.poster)) or site.logo }}"
    url: "{{ site.url ~ '/show/' ~ show.slug ~ '/' }}"
    ogType: "article"
---

{%- set showEvents = [] -%}
{%- for event in events -%}
    {%- if event.show == show.slug -%}
        {%- set showEvents = (showEvents.push({
            date: event.date,
            time: event.time,
            title: event.title,
            poster: event.poster or show.poster,
            ticketUrl: null if event.freeAtDoor else (event.ticketUrl or show.ticketUrl),
            freeAtDoor: event.freeAtDoor,
            slug: event | eventSlug,
            shortName: event | eventShortName(show)
        }), showEvents) -%}
    {%- endif -%}
{%- endfor -%}

<script id="show-data" type="application/json">
{{ {
    slug: show.slug,
    title: show.title,
    poster: show.poster,
    ticketUrl: show.ticketUrl,
    createEventPages: show.createEventPages,
    showAllEvents: show.showAllEvents,
    nextEventLabel: show.nextEventLabel or "Next Show",
    buttonText: show.buttonText or "Buy Tickets",
    events: showEvents,
    site: {
        url: site.url,
        name: site.name,
        logo: site.logo,
        address: site.address
    }
} | dump | safe }}
</script>
{%- set schemaJson = show | showEventsSchema(events, site) -%}
{%- if schemaJson %}
<script type="application/ld+json">{{ schemaJson | safe }}</script>
{%- endif %}

<div>
    <div class="flex flex-col md:flex-row gap-12">
        {%- if show.poster %}
        <div class="w-full md:w-1/2 shrink-0">
            <div class="aspect-[3/4] bg-neutral-900 overflow-hidden">
                <img id="show-poster" src="/posters/{{ show.poster }}" alt="{{ show.title }}" class="w-full h-full object-cover">
            </div>
        </div>
        {%- endif %}

        <div class="flex-1">
            <h1 class="font-oswald font-bold text-5xl uppercase mb-6">{{ show.title }}</h1>

            <p class="font-inter text-2xl text-neutral-300 mb-8">{{ show.tagline }}</p>

            {%- if show.ticketUrl %}
            <div id="static-ticket-button" class="mb-8">
                <a href="{{ show.ticketUrl }}" target="_blank" rel="noopener"
                    class="inline-block bg-white text-black font-inter text-base font-semibold px-6 py-3 hover:bg-neutral-200 transition-colors">
                    {{ show.buttonText or "Buy Tickets" }}
                </a>
            </div>
            {%- endif %}

            <div id="next-event-card" class="hidden"></div>

            {%- if show.description %}
            <p class="font-inter text-lg text-neutral-400 mb-10 leading-normal whitespace-pre-line">{{ show.description }}</p>
            {%- endif %}

            {%- if show.faq %}
            <div class="mt-8 mb-10">
                <h2 class="font-oswald text-2xl uppercase mb-4">FAQ</h2>
                <div class="space-y-6">
                    {%- for item in show.faq %}
                    <div>
                        <p class="font-inter text-lg text-white mb-1">{{ item.question }}</p>
                        <p class="font-inter text-lg text-neutral-400 leading-normal whitespace-pre-line">{{ item.answer }}</p>
                    </div>
                    {%- endfor %}
                </div>
            </div>
            {%- endif %}

            {%- if show.isIndex %}
            <div id="upcoming-events-section" class="mt-8 hidden">
                <h2 class="font-oswald text-2xl uppercase mb-4">Upcoming Shows</h2>
                <div id="upcoming-events-list" class="space-y-3"></div>
            </div>
            {%- endif %}
        </div>
    </div>
</div>

<script>
(function() {
    const dataEl = document.getElementById('show-data');
    if (!dataEl) return;

    const data = JSON.parse(dataEl.textContent);
    const today = new Date().toISOString().split('T')[0];

    // Find next upcoming event
    const upcomingEvents = data.events.filter(e => e.date >= today);
    const nextEvent = upcomingEvents[0];

    // Format date like "Saturday, February 28, 2026"
    function formatLongDate(dateStr) {
        const date = new Date(dateStr + 'T12:00:00');
        return date.toLocaleDateString('en-US', {
            weekday: 'long',
            year: 'numeric',
            month: 'long',
            day: 'numeric'
        });
    }

    // Build the card for a single event. Label is omitted when listing every event.
    function renderEventCard(event, label) {
        const showEventPoster = data.createEventPages && event.title && event.poster;

        let html = `<div class="bg-neutral-900 border border-neutral-700 mb-8 overflow-hidden ${showEventPoster ? 'h-64' : ''}">
            <div class="flex h-full">`;

        if (showEventPoster) {
            html += `<div class="shrink-0 h-full p-3">
                <img src="/posters/${event.poster}" alt="${event.shortName}" class="h-full w-auto object-contain">
            </div>`;
        }

        html += `<div class="p-6 flex-1">`;

        if (label) {
            html += `<p class="font-inter text-sm text-neutral-400 uppercase tracking-wide mb-2">${label}</p>`;
        }

        if (data.createEventPages && event.title) {
            html += `<p class="font-oswald text-2xl text-white mb-2">
                <a href="/show/${data.slug}/${event.slug}/" class="hover:text-neutral-300">${event.shortName}</a>
            </p>`;
        }

        html += `<p class="font-inter text-lg text-white mb-1">${formatLongDate(event.date)}</p>
            <p class="font-inter text-neutral-300 mb-4">${event.time}</p>`;

        if (event.ticketUrl) {
            html += `<a href="${event.ticketUrl}" target="_blank" rel="noopener"
                class="inline-block bg-white text-black font-inter text-base font-semibold px-6 py-3 hover:bg-neutral-200 transition-colors">
                ${data.buttonText}
            </a>`;
        } else if (event.freeAtDoor) {
            html += `<p class="font-inter text-base text-white">Free at the door</p>`;
        }

        html += `</div></div></div>`;
        return html;
    }

    // showAllEvents gives every upcoming event its own unlabelled card;
    // otherwise just the next one, labelled.
    const cardEvents = data.showAllEvents ? upcomingEvents : (nextEvent ? [nextEvent] : []);

    if (cardEvents.length) {
        const card = document.getElementById('next-event-card');
        card.innerHTML = cardEvents
            .map(e => renderEventCard(e, data.showAllEvents ? null : data.nextEventLabel))
            .join('');
        card.classList.remove('hidden');

        // Hide the static ticket button since the cards have their own
        const staticBtn = document.getElementById('static-ticket-button');
        if (staticBtn) staticBtn.classList.add('hidden');

        // Update main poster if the leading event has a different one
        const leadEvent = cardEvents[0];
        if (leadEvent.poster && leadEvent.poster !== data.poster) {
            const posterImg = document.getElementById('show-poster');
            if (posterImg) posterImg.src = '/posters/' + leadEvent.poster;
        }
    }

    // Render upcoming events list (for isIndex shows)
    const upcomingSection = document.getElementById('upcoming-events-section');
    const upcomingList = document.getElementById('upcoming-events-list');
    if (upcomingSection && upcomingList && !data.showAllEvents) {
        // Always skip first event since it's shown in the Next Show card above
        const eventsToShow = nextEvent ? upcomingEvents.slice(1) : upcomingEvents;

        if (eventsToShow.length > 0) {
            let html = '';
            for (const event of eventsToShow) {
                html += `<div class="flex items-center justify-between bg-neutral-800 p-4">
                    <div>`;

                if (data.createEventPages && event.title) {
                    html += `<a href="/show/${data.slug}/${event.slug}/" class="font-inter text-white hover:text-neutral-300">${event.shortName}</a>`;
                } else {
                    html += `<p class="font-inter text-white">${event.shortName}</p>`;
                }

                html += `<p class="font-inter text-sm text-neutral-400">${formatLongDate(event.date)} @ ${event.time}</p>
                    </div>`;

                if (event.ticketUrl) {
                    html += `<a href="${event.ticketUrl}" target="_blank" rel="noopener" class="font-inter text-sm bg-white text-black px-4 py-2 hover:bg-neutral-200 transition-colors">
                        Tickets
                    </a>`;
                }

                html += `</div>`;
            }
            upcomingList.innerHTML = html;
            upcomingSection.classList.remove('hidden');
        }
    }
})();
</script>